# Optional app settings (database is SQLite at prisma/dev.db — see prisma/schema.prisma)

# CRON_SECRET=change-me-in-production

DAILY_REPORT_TIMEZONE=UTC

# Optional: Slack Appbird channel ingest (see README)
# SLACK_APPBIRD_ENABLED=1
# SLACK_BOT_TOKEN=xoxb-...
# Comma-separated channel ids (#appbird-market-stats, #apple-new-games, #googleplay-new-games)
# SLACK_APPBIRD_CHANNEL_IDS=C1111111111,C2222222222,C3333333333
# SLACK_APPBIRD_MESSAGE_LIMIT=100

# Optional: Developer wishlist discovery (see README)
# DEVELOPER_WISHLIST_MAX_APPS_PER_DEVELOPER=60

# Optional: Inspiration (Reddit videos) feed
# VIDEOS_REDDIT_SUBREDDITS=indiegames,gamedev,indiehackers
# VIDEOS_REDDIT_LIMIT_PER_SUB=20
# VIDEOS_INCLUDE_NSFW=0
# VIDEOS_YOUTUBE_CHANNELS=https://www.youtube.com/@musthavegames_androidgameplay
# VIDEOS_YOUTUBE_LIMIT_PER_CHANNEL=12
